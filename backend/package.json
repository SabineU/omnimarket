    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@prisma/config": "^7.8.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.12.2",
    "@types/pg": "^8.20.0",
