{
  "name": "@omnimarket/backend",
  "version": "1.0.0",
  "private": true,
  "description": "OmniMarket REST API – Express + TypeScript + Prisma",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
